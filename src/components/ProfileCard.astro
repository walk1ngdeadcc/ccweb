---
// ProfileCard - 入场后居中显示的个人卡片
// 点击进入后翻转缩小到左上角头像
// 点击头像再次展开卡片
---

<!-- 模糊遮罩 -->
<div class="profile-blur-overlay" id="profileBlur"></div>

<!-- 左上角小头像 -->
<div class="profile-avatar-small" id="profileAvatarSmall">
  <img src="/images/头像.jpg" alt="avatar" />
</div>

<!-- 居中卡片 -->
<div class="profile-card-wrapper" id="profileCard">
  <div class="profile-card-inner" id="profileCardInner">
    <!-- 正面 -->
    <div class="profile-card-front">
      <div class="profile-card-glow"></div>
      <img class="profile-avatar-large" src="/images/头像.jpg" alt="avatar" />
      <div class="profile-card-name">CC</div>
      <div class="profile-card-bio">嵌入式开发 / 学习记录</div>
      <button class="profile-enter-btn" id="profileEnterBtn">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
        </svg>
        <span>进入笔记</span>
      </button>
      <div class="profile-social-links">
        <a class="profile-social-btn github" href="https://github.com" target="_blank" rel="noopener" title="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a class="profile-social-btn douyin" href="https://www.douyin.com/" target="_blank" rel="noopener" title="抖音">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43V13.2a8.16 8.16 0 005.58 2.16V12a4.85 4.85 0 01-2.01-.43V6.69h2.01z"/></svg>
        </a>
        <a class="profile-social-btn link" href="" target="_blank" rel="noopener" title="链接">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        </a>
      </div>
    </div>
    <!-- 背面（翻转时显示） -->
    <div class="profile-card-back">
      <img src="/images/头像.jpg" alt="avatar" />
    </div>
  </div>
</div>
