---
interface Props {
  title: string;
  summary?: string;
  category: string;
  tags: string[];
  date: string;
  slug: string;
  favorite?: boolean;
}

const { title, summary, category, tags, date, slug, favorite } = Astro.props;
---
<a href={`/notes/${slug}/`} class="glass-card block p-5 sm:p-6 group">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="text-base font-semibold text-text-main group-hover:text-primary transition-colors line-clamp-1">
      {title}
    </h3>
    {favorite && (
      <span class="text-amber-400 text-sm flex-shrink-0" title="收藏">★</span>
    )}
  </div>
  
  {summary && (
    <p class="text-sm text-text-secondary line-clamp-2 mb-3 leading-relaxed">{summary}</p>
  )}
  
  <div class="flex flex-wrap items-center gap-2 mt-auto">
    <span class="text-xs px-2.5 py-1 rounded-full bg-primary/10 text-primary font-medium">
      {category}
    </span>
    {tags.slice(0, 3).map(tag => (
      <span class="text-xs text-text-weak">#{tag}</span>
    ))}
    {tags.length > 3 && (
      <span class="text-xs text-text-weak">+{tags.length - 3}</span>
    )}
  </div>
  
  <div class="mt-3 pt-3 border-t border-white/5 flex items-center justify-between">
    <span class="text-xs text-text-weak">{date}</span>
    <span class="text-xs text-primary opacity-0 group-hover:opacity-100 transition-opacity">阅读 →</span>
  </div>
</a>
