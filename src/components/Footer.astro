---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/5 mt-20 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-weak">
      <div class="flex items-center gap-2">
        <span>🧑‍💻</span>
        <span>ZeroOne Notes</span>
        <span class="hidden sm:inline">·</span>
        <span class="hidden sm:inline">把零散知识点，整理成自己的系统</span>
      </div>
      <div class="flex items-center gap-4">
        <span>© {year}</span>
        <a href="/about" class="hover:text-primary transition-colors">关于</a>
      </div>
    </div>
  </div>
</footer>
