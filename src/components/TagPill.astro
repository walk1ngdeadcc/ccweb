---
interface Props {
  name: string;
  count?: number;
  href?: string;
}

const { name, count, href } = Astro.props;
---
{href ? (
  <a 
    href={href}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-white/5 border border-white/10 text-text-secondary hover:text-primary hover:border-primary/30 hover:bg-primary/5 transition-all"
  >
    <span>#{name}</span>
    {count !== undefined && (
      <span class="text-xs text-text-weak">{count}</span>
    )}
  </a>
) : (
  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-white/5 border border-white/10 text-text-secondary">
    <span>#{name}</span>
    {count !== undefined && (
      <span class="text-xs text-text-weak">{count}</span>
    )}
  </span>
)}
