---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.filter(n => !n.data.draft).map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

// 字数统计
function countWords(text: string) {
  const clean = text
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]+`/g, '')
    .replace(/\[[^\]]*\]\([^\)]*\)/g, '')
    .replace(/!\[[^\]]*\]\([^\)]*\)/g, '')
    .replace(/[#*\-_>\|]/g, '')
    .replace(/\s+/g, '');
  const cn = (clean.match(/[\u4e00-\u9fa5]/g) || []).length;
  const en = (clean.match(/[a-zA-Z]+/g) || []).length;
  return cn + en;
}

const wordCount = countWords(note.body);
const readTime = Math.max(1, Math.ceil(wordCount / 400));

// 从 markdown 提取标题
const headings: { level: number; text: string }[] = [];
const lines = note.body.split('\n');
for (const line of lines) {
  const match = line.trimEnd().match(/^(#{2,3})\s+(.+)$/);
  if (match) {
    headings.push({
      level: match[1].length,
      text: match[2].trim(),
    });
  }
}
---
<BaseLayout title={`${note.data.title} | ZeroOne Notes`} description={note.data.summary}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Main Content -->
      <article class="lg:col-span-8" id="article-content">
        <div class="mb-6">
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <a 
              href={`/categories/${encodeURIComponent(note.data.category)}/`}
              class="text-xs px-2.5 py-1 rounded-full bg-primary/10 text-primary font-medium hover:bg-primary/20 transition-colors"
            >
              {note.data.category}
            </a>
            {note.data.favorite && (
              <span class="text-xs px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-400 font-medium">★ 收藏</span>
            )}
            {note.data.difficulty && (
              <span class="text-xs px-2.5 py-1 rounded-full bg-white/5 text-text-weak">{note.data.difficulty}</span>
            )}
          </div>
          
          <h1 class="text-2xl sm:text-3xl font-bold text-text-main mb-3">{note.data.title}</h1>
          
          <div class="flex flex-wrap items-center gap-3 text-sm text-text-weak">
            <span>{note.data.date}</span>
            {note.data.updated && (
              <span>更新于 {note.data.updated}</span>
            )}
            <span class="text-text-weak/40">|</span>
            <span>{wordCount} 字</span>
            <span class="text-text-weak/40">|</span>
            <span>约 {readTime} 分钟</span>
          </div>
        </div>
        
        <div class="glass-card p-6 sm:p-8">
          <div class="prose max-w-none">
            <Content />
          </div>
        </div>
        
        <!-- Tags -->
        <div class="mt-6 flex flex-wrap gap-2">
          {note.data.tags.map(tag => (
            <a 
              href={`/tags/${encodeURIComponent(tag)}/`}
              class="text-sm text-text-secondary hover:text-primary transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </article>
      
      <!-- Sidebar: TOC -->
      <aside class="lg:col-span-4 hidden lg:block">
        <div 
          class="fixed top-1/2 glass-card p-5 w-60 max-h-[80vh] overflow-y-auto z-30"
          style="transform: translateY(-50%); right: max(1.5rem, calc((100vw - 72rem) / 2 + 1.5rem));"
        >
          <h3 class="text-sm font-semibold text-text-main mb-3 text-center">目录</h3>
          {headings.length > 0 ? (
            <nav class="space-y-1.5 overflow-y-auto" id="toc-nav">
              {headings.map(h => (
                <a 
                  href={`#${h.text}`}
                  class={`block text-sm transition-colors hover:text-primary toc-link leading-relaxed text-center ${
                    h.level === 2 ? 'text-text-secondary' : 'text-text-weak'
                  }`}
                  data-level={h.level}
                  data-text={h.text}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          ) : (
            <p class="text-sm text-text-weak text-center">暂无目录</p>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- Scroll Progress Ring -->
  <div 
    id="scrollTopBtn"
    class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full cursor-pointer hidden items-center justify-center group bg-page-bg/80 backdrop-blur-sm border border-white/10 shadow-lg transition-all hover:scale-110"
    title="回到顶部"
  >
    <svg class="w-12 h-12 -rotate-90" viewBox="0 0 48 48">
      <circle
        cx="24" cy="24" r="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="text-white/10"
      />
      <circle
        id="progressCircle"
        cx="24" cy="24" r="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="text-primary transition-all duration-150"
        stroke-dasharray="125.6"
        stroke-dashoffset="125.6"
      />
    </svg>
    <!-- Percentage text -->
    <span id="progressText" class="absolute text-[10px] font-semibold text-text-secondary group-hover:opacity-0 transition-opacity">0%</span>
    <!-- Arrow icon on hover -->
    <svg 
      class="absolute w-5 h-5 text-primary opacity-0 group-hover:opacity-100 transition-opacity" 
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </div>

  <script>
    (function() {
      // TOC: fix hrefs to match rendered heading ids
      const tocNav = document.getElementById('toc-nav');
      const article = document.querySelector('.prose');
      if (tocNav && article) {
        const headings = article.querySelectorAll('h2, h3');
        const links = tocNav.querySelectorAll('a');
        links.forEach((link, i) => {
          const heading = headings[i];
          if (heading && heading.id) {
            link.href = '#' + heading.id;
          }
        });
        
        // Scroll spy: highlight current heading
        function updateActiveToc() {
          const scrollY = window.scrollY + 80;
          let activeIndex = -1;
          headings.forEach((h, i) => {
            if (h.offsetTop <= scrollY) activeIndex = i;
          });
          links.forEach((link, i) => {
            if (i === activeIndex) {
              link.classList.add('text-primary');
              link.classList.remove('text-text-secondary', 'text-text-weak');
            } else {
              link.classList.remove('text-primary');
              const level = parseInt(link.dataset.level || '2');
              link.classList.add(level === 2 ? 'text-text-secondary' : 'text-text-weak');
            }
          });
        }
        window.addEventListener('scroll', updateActiveToc);
        updateActiveToc();

        // Smooth scroll for TOC links
        links.forEach(link => {
          link.addEventListener('click', (e) => {
            const href = link.getAttribute('href');
            if (href && href.startsWith('#')) {
              const target = document.getElementById(href.slice(1));
              if (target) {
                e.preventDefault();
                const headerOffset = 80;
                const y = target.getBoundingClientRect().top + window.scrollY - headerOffset;
                window.scrollTo({ top: y, behavior: 'smooth' });
                history.pushState(null, '', href);
              }
            }
          });
        });
      }

      // Scroll progress ring
      const btn = document.getElementById('scrollTopBtn');
      const circle = document.getElementById('progressCircle');
      const text = document.getElementById('progressText');
      const circumference = 2 * Math.PI * 20;
      
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(1, Math.max(0, scrollTop / docHeight)) : 0;
        const offset = circumference - progress * circumference;
        
        if (circle) circle.style.strokeDashoffset = offset.toString();
        if (text) text.textContent = Math.round(progress * 100) + '%';
        
        if (btn) {
          if (scrollTop > 100) {
            btn.classList.remove('hidden');
            btn.classList.add('flex');
          } else {
            btn.classList.add('hidden');
            btn.classList.remove('flex');
          }
        }
      }
      
      window.addEventListener('scroll', updateProgress);
      updateProgress();
      
      btn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();
  </script>
</BaseLayout>
