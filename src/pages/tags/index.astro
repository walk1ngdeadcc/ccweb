---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allNotes = await getCollection('notes');
const notes = allNotes.filter(n => !n.data.draft);

const tagMap = new Map<string, number>();
notes.forEach(n => {
  n.data.tags.forEach(t => {
    tagMap.set(t, (tagMap.get(t) || 0) + 1);
  });
});

const tags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="标签云 | ZeroOne Notes" current="tags">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text-main mb-3">标签云</h1>
      <p class="text-text-secondary text-sm">共 {tags.length} 个标签</p>
    </div>
    
    <div class="flex flex-wrap gap-3 justify-center">
      {tags.map(([name, count]) => {
        const size = Math.max(0.85, Math.min(1.3, 0.85 + count * 0.1));
        return (
          <a 
            href={`/tags/${encodeURIComponent(name)}/`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-text-secondary hover:text-primary hover:border-primary/30 hover:bg-primary/5 transition-all"
            style={`font-size: ${size}rem;`}
          >
            <span>#{name}</span>
            <span class="text-xs text-text-weak">{count}</span>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
