---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NoteCard from '../components/NoteCard.astro';

const allNotes = await getCollection('notes');
const notes = allNotes
  .filter(n => !n.data.draft && n.data.favorite)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="收藏笔记 | ZeroOne Notes" current="favorites">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-8 sm:mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text-main mb-3">收藏笔记</h1>
      <p class="text-text-secondary text-sm">共 {notes.length} 篇收藏的笔记</p>
    </div>
    
    {notes.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {notes.map(note => (
          <NoteCard 
            title={note.data.title}
            summary={note.data.summary}
            category={note.data.category}
            tags={note.data.tags}
            date={note.data.date}
            slug={note.slug}
            favorite={note.data.favorite}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-4xl mb-4">⭐</div>
        <p class="text-text-secondary">还没有收藏任何笔记</p>
        <a href="/notes" class="text-primary hover:underline text-sm mt-2 inline-block">去浏览笔记 →</a>
      </div>
    )}
  </div>
</BaseLayout>
